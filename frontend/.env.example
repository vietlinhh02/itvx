# Backend base URL used by server-side routes and frontend rewrites.
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# NextAuth secret for local development.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-base64-secret

# Google OAuth credentials used by the frontend auth flow.
# These should usually match GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in the root .env.
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Public LiveKit URL used by the candidate live interview room.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
